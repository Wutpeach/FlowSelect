{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowselect.app/schemas/runtime-sidecars-manifest.schema.json",
  "title": "FlowSelect Runtime Sidecars Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "component",
    "flowselectSidecarVersion",
    "upstreamVersion",
    "generatedAt",
    "artifacts"
  ],
  "properties": {
    "component": {
      "type": "string",
      "minLength": 1
    },
    "flowselectSidecarVersion": {
      "type": "string",
      "minLength": 1
    },
    "upstreamVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component",
          "flowselectSidecarVersion",
          "upstreamVersion",
          "target",
          "url",
          "sha256",
          "size",
          "publishedAt"
        ],
        "properties": {
          "component": {
            "type": "string",
            "minLength": 1
          },
          "flowselectSidecarVersion": {
            "type": "string",
            "minLength": 1
          },
          "upstreamVersion": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "publishedAt": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
          },
          "minAppVersion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
