{
  "name": "flowselect",
  "private": true,
  "version": "0.2.9",
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/build-runtime-proxies.mjs --profile debug",
    "dev": "vite",
    "dev:all": "node ./scripts/dev-all.mjs",
    "dev:all:unix": "sh ./scripts/dev-all.sh",
    "dev:all:win": "cmd /c .\\scripts\\dev-all.cmd",
    "version:set": "node ./scripts/update-version.mjs",
    "locales:sync": "node ./scripts/sync-locales.mjs",
    "prebuild": "npm run locales:sync && node ./scripts/build-runtime-proxies.mjs --profile release",
    "build": "tsc && vite build",
    "build:runtime-proxies": "node ./scripts/build-runtime-proxies.mjs --profile release",
    "build:pinterest-sidecar": "node ./scripts/build-pinterest-sidecar.mjs",
    "package:browser-extension": "node ./scripts/package-browser-extension.mjs",
    "package:macos-open-source-dmg": "node ./scripts/package-macos-open-source-dmg.mjs",
    "check:pinterest-sidecar-upstream": "node ./scripts/check-pinterest-sidecar-upstream.mjs",
    "manifest:runtime-sidecars": "node ./scripts/generate-runtime-sidecars-manifest.mjs",
    "manifest:runtime-sidecars:validate": "node ./scripts/validate-runtime-sidecars-manifest.mjs",
    "lint": "eslint src vite.config.ts --ext .ts,.tsx",
    "smoke:pinterest-sidecar": "node ./scripts/smoke-pinterest-sidecar.mjs",
    "type-check": "tsc --noEmit",
    "typecheck": "npm run type-check",
    "test": "vitest run --passWithNoTests",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node ./scripts/run-tauri.mjs build",
    "package:portable": "powershell -ExecutionPolicy Bypass -File ./scripts/package-portable.ps1",
    "package:portable:skip-build": "powershell -ExecutionPolicy Bypass -File ./scripts/package-portable.ps1 -SkipBuild"
  },
  "dependencies": {
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.6.3",
    "lucide-react": "^0.563.0",
    "motion": "^12.35.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.2.3",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
