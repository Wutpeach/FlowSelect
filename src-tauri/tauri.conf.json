{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowSelect",
  "version": "0.2.5",
  "identifier": "com.flowselect.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "FlowSelect",
        "width": 200,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "dragDropEnabled": false,
        "backgroundColor": "#00000000",
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/yt-dlp*": "binaries/",
      "binaries/deno*": "binaries/",
      "binaries/pinterest-dl*": "binaries/",
      "resources/locales/": "locales/"
    }
  }
}
