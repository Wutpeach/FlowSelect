{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowSelect",
  "version": "0.2.7-rc2",
  "identifier": "com.flowselect.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "FlowSelect",
        "width": 200,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "dragDropEnabled": false,
        "backgroundColor": "#00000000",
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/flowselect-cli-proxy*": "binaries/",
      "binaries/yt-dlp*": "binaries/",
      "resources/locales/": "locales/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3RUQ2REVFNzE1RDQ2MTYKUldRV1JsMXg3bTN0RjBHZkNFUzFic2lFNTJDMFVHT0pmYUo1c3BzTlhHRktlNW9KcTlNaWJpd3oK",
      "endpoints": [
        "https://github.com/Wutpeach/FlowSelect/releases/latest/download/latest.json"
      ]
    }
  }
}
