#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

choose_python() {
  local candidates=(
    "$SCRIPT_DIR/../../.venv/bin/python"
    "$SCRIPT_DIR/../../../.venv/bin/python"
  )

  for candidate in "${candidates[@]}"; do
    if [ -x "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done

  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return 0
  fi

  return 1
}

PYTHON_BIN="$(choose_python || true)"
if [ -z "$PYTHON_BIN" ]; then
  echo "python3 not found for yt-dlp sidecar" >&2
  exit 1
fi

if "$PYTHON_BIN" -c "import yt_dlp" >/dev/null 2>&1; then
  exec "$PYTHON_BIN" -m yt_dlp "$@"
fi

if [ "${FLOWSELECT_YTDLP_SKIP_BOOTSTRAP:-0}" = "1" ]; then
  echo "yt_dlp module missing and bootstrap is disabled for status check" >&2
  exit 1
fi

echo "yt_dlp module missing, attempting bootstrap install..." >&2
install_attempts=(
  "--disable-pip-version-check -q yt-dlp"
  "--disable-pip-version-check --user -q yt-dlp"
  "--disable-pip-version-check --user --break-system-packages -q yt-dlp"
)

for attempt in "${install_attempts[@]}"; do
  if "$PYTHON_BIN" -m pip install ${attempt} >/dev/null 2>&1; then
    exec "$PYTHON_BIN" -m yt_dlp "$@"
  fi
done

echo "No module named yt_dlp. Install manually: python3 -m pip install --user --break-system-packages yt-dlp" >&2
exit 1
