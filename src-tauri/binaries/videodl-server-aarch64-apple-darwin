#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/../../.venv/bin/python"
DEV_SERVER="$SCRIPT_DIR/../../scripts/videodl_http_server.py"

if [ ! -f "$DEV_SERVER" ]; then
  echo "videodl server script not found: $DEV_SERVER" >&2
  exit 1
fi

if [ -x "$VENV_PYTHON" ]; then
  exec "$VENV_PYTHON" "$DEV_SERVER" "$@"
fi

exec python3 "$DEV_SERVER" "$@"
