{
  "manifest_version": 3,
  "name": "FlowSelect Video Picker",
  "version": "1.0.0",
  "description": "Pick video elements from web pages for FlowSelect",
  "permissions": ["activeTab", "scripting", "cookies", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["twitter-detector.js"],
      "css": ["twitter-button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.douyin.com/*"],
      "js": ["douyin-detector.js"],
      "css": ["douyin-button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["youtube-detector.js"],
      "css": ["youtube-button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bilibili.com/*", "https://bilibili.com/*"],
      "js": ["control-style-utils.js", "bilibili-detector.js"],
      "css": ["bilibili-button.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.xiaohongshu.com/*",
        "https://xiaohongshu.com/*",
        "https://*.xhslink.com/*",
        "https://xhslink.com/*"
      ],
      "js": ["xiaohongshu-detector.js"],
      "css": ["xiaohongshu-button.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
